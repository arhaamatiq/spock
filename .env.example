# =============================================================================
# Spock AI RAG System - Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# =============================================================================
# OpenAI Configuration (Required for RAG)
# =============================================================================

# Your OpenAI API key (required)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Chat model for generating responses (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Embedding model for vectorizing documents (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Vector Store Configuration
# =============================================================================

# Directory where ChromaDB persists its data (default: ./chroma_store)
PERSIST_DIR=./chroma_store

# =============================================================================
# Text Splitting Configuration
# =============================================================================

# Maximum size of each text chunk in characters (default: 1000)
CHUNK_SIZE=1000

# Overlap between consecutive chunks in characters (default: 200)
CHUNK_OVERLAP=200

# =============================================================================
# Retrieval Configuration
# =============================================================================

# Number of relevant documents to retrieve for each query (default: 4)
RETRIEVAL_K=4

# Minimum relevance score (0.0 to 1.0) for retrieved documents (default: 0.0)
MIN_RELEVANCE_SCORE=0.0

# =============================================================================
# Session Configuration
# =============================================================================

# Maximum number of conversation turns to remember (default: 10)
MAX_HISTORY=10

# =============================================================================
# API Server Configuration (spock_api)
# =============================================================================

# API key for authenticating requests to the API
# If not set, authentication is disabled (development mode)
# In production, always set this to a strong, random value
API_KEY=your-api-key-here

# Header name for the API key (default: x-api-key)
API_KEY_HEADER=x-api-key

# Host to bind the API server to (default: 0.0.0.0)
API_HOST=0.0.0.0

# Port to bind the API server to (default: 8000)
API_PORT=8000

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed CORS origins (comma-separated list)
# Default: http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Allow credentials in CORS requests (default: true)
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# Logging Configuration
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# =============================================================================
# Application Configuration
# =============================================================================

# Enable debug mode (shows /docs endpoint, more verbose errors) (default: false)
DEBUG=false

# =============================================================================
# RAG Configuration Overrides (Optional)
# =============================================================================

# Override number of documents to retrieve (uses RETRIEVAL_K if not set)
# RAG_RETRIEVAL_K=4

# Override max chat history turns (uses MAX_HISTORY if not set)
# RAG_MAX_HISTORY=10

# =============================================================================
# Streaming Configuration
# =============================================================================

# Artificial delay between stream chunks in milliseconds (for testing) (default: 0)
STREAM_CHUNK_DELAY_MS=0
